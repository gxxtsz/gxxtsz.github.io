<h2 id="颜色对话框"><a href="#颜色对话框" class="headerlink" title="颜色对话框"></a>颜色对话框</h2><figure class="highlight sqf"><table><tr><td class="code"><pre><span class="line">import wx</span><br><span class="line"><span class="keyword">if</span> <span class="variable">__name__</span> == ”<span class="variable">__main__</span>”:</span><br><span class="line">    app = wx.PySimpleApp()</span><br><span class="line">    <span class="built_in">dialog</span> = wx.ColourDialog(None)</span><br><span class="line">    <span class="built_in">dialog</span>.GetColourData().SetChooseFull(<span class="literal">True</span>)</span><br><span class="line">    <span class="keyword">if</span> <span class="built_in">dialog</span>.ShowModal() == wx.ID_OK:</span><br><span class="line">        data = <span class="built_in">dialog</span>.GetColourData()</span><br><span class="line">        print ’You selected: %s\n’ % <span class="built_in">str</span>(data.GetColour().<span class="built_in">Get</span>())</span><br><span class="line">    <span class="built_in">dialog</span>.Destroy()</span><br></pre></td></tr></table></figure>

